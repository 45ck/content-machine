name: reverse-engineer-winner
description: Execute the reference-video reverse-engineering path and write reusable breakdown files under runs/{runId}/reverse-engineer.
entrySkill: reverse-engineer-winner
operatorNotes: flows/reverse-engineer-winner.md
defaultOutputDir: runs/{runId}/reverse-engineer
inputs:
  - name: videoPath
    description: Local path or URL for the reference short to analyze.
    required: true
  - name: outputDir
    description: Optional explicit output root; otherwise the flow binds runs/{runId}/reverse-engineer.
    required: false
  - name: includeFrameAnalysis
    description: Include frame analysis files alongside videospec and blueprint outputs.
    required: false
outputs:
  - name: videospec.v1.json
    description: Reverse-engineered VideoSpec file.
    required: true
  - name: theme.v1.json
    description: VideoTheme classification file when classification is enabled.
    required: false
  - name: blueprint.v1.json
    description: VideoBlueprint file for downstream script generation.
    required: false
