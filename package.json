{
  "name": "@45ck/content-machine",
  "version": "0.2.2",
  "description": "Short-form video skill pack for coding-agent CLIs, with reusable skills, 45ck/prompt-language flows, and media runtime scripts",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "cm": "dist/cli/index.cjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist/**",
    "agent/**",
    "assets/archetypes/**",
    "assets/fonts/**",
    "assets/templates/**",
    "src/**",
    "skills/**",
    "flows/**",
    "scripts/harness/**",
    "scripts/postinstall.mjs",
    "archive/README.md",
    "archive/legacy-cli/README.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && npm run build:cli && npm run build:lib && npm run build:lib:cjs",
    "build:cli": "esbuild src/cli/index.ts --bundle --platform=node --format=cjs --packages=external --log-override:empty-import-meta=silent --outfile=dist/cli/index.cjs",
    "build:lib": "esbuild src/index.ts --bundle --platform=node --format=esm --packages=external --log-override:empty-import-meta=silent --sourcemap --outfile=dist/index.js",
    "build:lib:cjs": "esbuild src/index.ts --bundle --platform=node --format=cjs --packages=external --log-override:empty-import-meta=silent --sourcemap --outfile=dist/index.cjs",
    "build:types": "tsc -p tsconfig.build.json --emitDeclarationOnly",
    "dev": "tsx watch src/cli/index.ts",
    "cm": "tsx src/cli/index.ts",
    "harness:doctor-report": "node --import tsx scripts/harness/doctor-report.ts",
    "harness:flow-catalog": "node --import tsx scripts/harness/flow-catalog.ts",
    "harness:run-flow": "node --import tsx scripts/harness/run-flow.ts",
    "harness:skill-catalog": "node --import tsx scripts/harness/skill-catalog.ts",
    "harness:generate-short": "node --import tsx scripts/harness/generate-short.ts",
    "harness:brief-to-script": "node --import tsx scripts/harness/brief-to-script.ts",
    "harness:ingest": "node --import tsx scripts/harness/ingest.ts",
    "harness:longform-highlight-select": "node --import tsx scripts/harness/longform-highlight-select.ts",
    "harness:highlight-approval": "node --import tsx scripts/harness/highlight-approval.ts",
    "harness:boundary-snap": "node --import tsx scripts/harness/boundary-snap.ts",
    "harness:source-media-analyze": "node --import tsx scripts/harness/source-media-analyze.ts",
    "harness:media-index": "node --import tsx scripts/harness/media-index.ts",
    "harness:style-profile-library": "node --import tsx scripts/harness/style-profile-library.ts",
    "harness:script-to-audio": "node --import tsx scripts/harness/script-to-audio.ts",
    "harness:timestamps-to-visuals": "node --import tsx scripts/harness/timestamps-to-visuals.ts",
    "harness:video-render": "node --import tsx scripts/harness/video-render.ts",
    "harness:publish-prep": "node --import tsx scripts/harness/publish-prep.ts",
    "harness:install-skill-pack": "node --import tsx scripts/harness/install-skill-pack.ts",
    "agent:doctor-report": "npm run harness:doctor-report",
    "agent:flow-catalog": "npm run harness:flow-catalog",
    "agent:run-flow": "npm run harness:run-flow",
    "agent:skill-catalog": "npm run harness:skill-catalog",
    "agent:generate-short": "npm run harness:generate-short",
    "agent:brief-to-script": "npm run harness:brief-to-script",
    "agent:ingest": "npm run harness:ingest",
    "agent:longform-highlight-select": "npm run harness:longform-highlight-select",
    "agent:highlight-approval": "npm run harness:highlight-approval",
    "agent:boundary-snap": "npm run harness:boundary-snap",
    "agent:source-media-analyze": "npm run harness:source-media-analyze",
    "agent:media-index": "npm run harness:media-index",
    "agent:style-profile-library": "npm run harness:style-profile-library",
    "agent:script-to-audio": "npm run harness:script-to-audio",
    "agent:timestamps-to-visuals": "npm run harness:timestamps-to-visuals",
    "agent:video-render": "npm run harness:video-render",
    "agent:publish-prep": "npm run harness:publish-prep",
    "agent:install-skill-pack": "npm run harness:install-skill-pack",
    "review:latest": "node scripts/review-latest.mjs",
    "glossary:gen": "node scripts/gen-glossary.mjs",
    "glossary:check": "node scripts/quality/check-ubiquitous-language.mjs",
    "ul:gen": "node scripts/gen-ubiquitous-language-ts.mjs",
    "repo-facts:gen": "bash scripts/quality/with-node20.sh node scripts/gen-repo-facts.mjs",
    "repo-facts:check": "bash scripts/quality/with-node20.sh node scripts/quality/check-repo-facts.mjs",
    "prompts:check": "bash scripts/quality/with-node20.sh node scripts/quality/check-prompts.mjs",
    "docs:lint": "bash scripts/quality/with-node20.sh node scripts/quality/docs-lint.mjs",
    "docs:linkcheck": "bash scripts/quality/with-node20.sh node scripts/quality/check-doc-links.mjs",
    "docs:check": "npm run docs:lint && npm run docs:linkcheck",
    "cspell:gen": "node scripts/gen-cspell.mjs",
    "cspell:check": "bash scripts/quality/with-node20.sh npx --no-install cspell lint --config cspell.json --no-progress README.md docs/README.md docs/dev/*.md docs/user/**/*.md docs/reference/**/*.md src/cli/**/*.{ts,tsx,js,mjs,cjs} src/harness/**/*.{ts,tsx,js,mjs,cjs} scripts/harness/**/*.{ts,tsx,js,mjs,cjs}",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "bash scripts/quality/with-node20.sh sh -c \"node scripts/quality/clean-coverage.mjs && CM_COVERAGE_SINGLE_WORKER=1 scripts/quality/vitest-coverage-retry.sh\"",
    "mutation": "stryker run",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --max-warnings 0 --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc --noEmit",
    "dup:check": "jscpd --config .jscpd.json",
    "quality": "npm run typecheck && npm run lint && npm run format:check && npm run test:run",
    "size": "size-limit",
    "size:check": "size-limit --json",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch",
    "eval": "npx promptfoo eval",
    "eval:script": "npx promptfoo eval -c evals/configs/cm-script.yaml",
    "postinstall": "node scripts/postinstall.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@google/generative-ai": "^0.24.1",
    "@iarna/toml": "^3.0.0",
    "@remotion/animation-utils": "^4.0.424",
    "@remotion/bundler": "^4.0.424",
    "@remotion/captions": "^4.0.424",
    "@remotion/cli": "^4.0.424",
    "@remotion/install-whisper-cpp": "^4.0.424",
    "@remotion/layout-utils": "^4.0.424",
    "@remotion/player": "^4.0.424",
    "@remotion/renderer": "^4.0.424",
    "@tavily/core": "^0.6.4",
    "adm-zip": "^0.5.16",
    "boxen": "^7.1.1",
    "chalk": "^5.3.0",
    "commander": "^14.0.2",
    "dotenv": "^17.2.3",
    "fastmcp": "^3.33.0",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "inquirer": "^13.1.0",
    "kokoro-js": "^1.2.1",
    "mustache": "^4.2.0",
    "openai": "^4.77.0",
    "ora": "^9.0.0",
    "pexels": "^1.4.0",
    "pino": "^10.1.1",
    "pino-pretty": "^13.1.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "remotion": "^4.0.424",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0",
    "yaml": "^2.4.0",
    "zod": "^3.23.0"
  },
  "optionalDependencies": {
    "@remotion/compositor-win32-x64-msvc": "^4.0.424"
  },
  "overrides": {
    "esbuild": "0.27.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@size-limit/file": "^12.0.0",
    "@stryker-mutator/core": "^9.5.1",
    "@types/adm-zip": "^0.5.7",
    "@types/inquirer": "^9.0.0",
    "@types/mustache": "^4.2.0",
    "@types/node": "^25.0.6",
    "@types/react": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.51.0",
    "@vitest/coverage-istanbul": "^2.1.9",
    "@vitest/coverage-v8": "^2.1.9",
    "cspell": "^9.2.0",
    "esbuild": "0.27.2",
    "eslint": "^9.0.0",
    "eslint-plugin-jsdoc": "^50.8.0",
    "eslint-plugin-sonarjs": "^3.0.5",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "jscpd": "^4.0.5",
    "lint-staged": "^16.2.7",
    "markdownlint-cli2": "^0.18.1",
    "msw": "^2.0.0",
    "playwright": "^1.58.2",
    "pngjs": "^7.0.0",
    "prettier": "^3.7.4",
    "promptfoo": "^0.120.11",
    "size-limit": "^12.0.0",
    "tsx": "^4.19.0",
    "typedoc": "^0.28.15",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.6.0"
  },
  "packageManager": "npm@10.8.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/45ck/content-machine.git"
  },
  "homepage": "https://github.com/45ck/content-machine#readme",
  "bugs": {
    "url": "https://github.com/45ck/content-machine/issues"
  },
  "keywords": [
    "video-generation",
    "short-form",
    "tiktok",
    "reels",
    "shorts",
    "remotion",
    "ffmpeg",
    "yt-dlp",
    "automation",
    "content-creation",
    "codex",
    "claude-code",
    "prompt-language",
    "agent-skills",
    "skills",
    "agent-runtime"
  ],
  "lint-staged": {
    "registry/repo-facts.yaml": [
      "node scripts/quality/lintstaged-repo-facts-gen.mjs"
    ],
    "*.{ts,tsx}": [
      "eslint --cache --cache-location .cache/eslint/ --max-warnings 0 --no-warn-ignored --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "size-limit": [
    {
      "path": "dist/cli/index.cjs",
      "limit": "5 MB"
    }
  ]
}
